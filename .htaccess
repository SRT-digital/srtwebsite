# ============================================
# SRT Digital Solutions - Performance & Security
# ============================================

# ------------------------------
# ERROR PAGES
# ------------------------------
ErrorDocument 404 /404.html
ErrorDocument 500 /404.html

# ------------------------------
# 1. GZIP COMPRESSION
# ------------------------------
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css
  AddOutputFilterByType DEFLATE application/javascript application/x-javascript application/json
  AddOutputFilterByType DEFLATE application/ld+json application/xml
  AddOutputFilterByType DEFLATE image/svg+xml
  AddOutputFilterByType DEFLATE font/woff2 application/font-woff2
</IfModule>

# ------------------------------
# 2. BROWSER CACHING
# ------------------------------
<IfModule mod_expires.c>
  ExpiresActive On

  # HTML - no cache (always fetch latest)
  ExpiresByType text/html "access plus 0 seconds"

  # CSS & JS - 1 year cache
  ExpiresByType text/css "access plus 1 year"
  ExpiresByType application/javascript "access plus 1 year"
  ExpiresByType application/x-javascript "access plus 1 year"

  # Images - 1 year cache
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType image/gif "access plus 1 year"
  ExpiresByType image/x-icon "access plus 1 year"

  # Fonts - 1 year cache
  ExpiresByType font/woff2 "access plus 1 year"
  ExpiresByType font/woff "access plus 1 year"
  ExpiresByType application/font-woff2 "access plus 1 year"
  ExpiresByType application/font-woff "access plus 1 year"

  # JSON/XML - 1 hour cache
  ExpiresByType application/json "access plus 1 hour"
  ExpiresByType application/ld+json "access plus 1 hour"
</IfModule>

<IfModule mod_headers.c>
  # HTML - always revalidate (so new content shows immediately)
  <FilesMatch "\.(html)$">
    Header set Cache-Control "no-cache, must-revalidate"
  </FilesMatch>

  # Custom SRT scripts (srt-cms.js, srt-blog.js, admin-*.js etc.) - always check for updates
  # This prevents stale CMS/admin code from being cached across deploys
  <FilesMatch "(srt-[a-z]+\.js|admin-[a-z]+\.js|supabase-config\.js)$">
    Header set Cache-Control "no-cache, must-revalidate, max-age=0"
  </FilesMatch>

  # Vendor libraries & static assets - immutable long cache (these rarely change)
  <FilesMatch "\.(css|png|jpg|jpeg|webp|gif|svg|woff2|woff|eot|ttf)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>

  # Vendor JS (jquery, gsap, bootstrap, swiper, etc.) - long cache
  <FilesMatch "(jquery|bootstrap|gsap|swiper|isotope|magnific|waypoints|imagesloaded|counterup|Scroll|Split|animation\.min|main)\.js$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
</IfModule>

# ------------------------------
# 3. WEBP AUTO-SERVE
# ------------------------------
<IfModule mod_rewrite.c>
  RewriteEngine On

  # Serve WebP images when browser supports it and .webp file exists
  RewriteCond %{HTTP_ACCEPT} image/webp
  RewriteCond %{REQUEST_FILENAME} \.(png|jpg|jpeg)$
  RewriteCond %{REQUEST_FILENAME}\.webp -f
  RewriteRule ^(.+)\.(png|jpg|jpeg)$ $1.$2.webp [T=image/webp,L]
</IfModule>

# Add Vary header for proper CDN/proxy caching
<IfModule mod_headers.c>
  <FilesMatch "\.(png|jpg|jpeg)$">
    Header append Vary Accept
  </FilesMatch>
</IfModule>

# Correct MIME type for WebP
AddType image/webp .webp

# ------------------------------
# 4. SECURITY HEADERS
# ------------------------------
<IfModule mod_headers.c>
  Header set X-Content-Type-Options "nosniff"
  Header set X-Frame-Options "SAMEORIGIN"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
  Header set X-XSS-Protection "1; mode=block"
  Header set Permissions-Policy "camera=(), microphone=(), geolocation=()"
</IfModule>

# Prevent directory listing
Options -Indexes

# Protect sensitive files
<FilesMatch "\.(scss|map|bak|log|sql)$">
  <IfModule mod_authz_core.c>
    Require all denied
  </IfModule>
</FilesMatch>
