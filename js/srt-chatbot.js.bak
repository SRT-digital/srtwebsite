        { id:'contact_info', keys:['contact','phone','email','number','call','whatsapp','reach','connect','how to contact','mail','get in touch'], w:2 },

        /* ── Patient / Clinic Growth ── */
        { id:'patients', keys:['patient','patients','more patients','get patients','attract patients','patient flow','footfall','walk in','appointment','booking','new patients','patient acquisition','grow practice','clinic growth','increase patients'], w:2 },
