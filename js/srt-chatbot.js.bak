        /* ── General ── */
        { id:'help', keys:['help','assist','support','guide','need help','can you help','what can you do','what do you do','service','services','offer','offering'], w:2 },
        { id:'blog', keys:['blog','article','read','guide','learn','resource','tips','information','knowledge'], w:2 }
      ];

      function detectIntent(text) {
        var n = normalize(text);
        var scores = {};
        intents.forEach(function(intent) {
          var score = 0;
          intent.keys.forEach(function(key) {
            if (n.indexOf(key) > -1) {
              // Longer key = more specific = more weight
              score += intent.w * (1 + key.split(' ').length * 0.5);
            }
          });
          if (score > 0) scores[intent.id] = score;
        });
        // Sort by score descending
        var sorted = Object.keys(scores).sort(function(a,b){ return scores[b]-scores[a]; });
        return { top: sorted[0] || 'unknown', all: sorted.slice(0,3), scores: scores };
      }

      /* ─── Quick Reply renderer ─── */
      function showQuickReplies(items) {
        var qr = document.getElementById('quickReplies');
        qr.innerHTML = '';
        items.forEach(function(item) {
