            }
            else if (n2.indexOf('portfolio') > -1 || n2.indexOf('sample') > -1 || n2.indexOf('example') > -1 || n2.indexOf('case study') > -1 || n2.indexOf('previous work') > -1) {
              fallbackReply = 'You can see our work and approach:' + br(2) + '&bull; ' + link('./index.html#projects','View our portfolio') + ' &mdash; Website, branding, and SEO work' + br() + '&bull; ' + link('./blog.html','Read our blog') + ' &mdash; In-depth guides showcasing our expertise' + br(2) + 'For specific case studies and results from healthcare clients, ' + CTA_BOOK + ' and we will share relevant examples for your specialty.';
            }
            else if (n2.indexOf('tamil') > -1 || n2.indexOf('language') > -1 || n2.indexOf('regional') > -1) {
              fallbackReply = 'Yes! We create content in '+bold('both Tamil and English')+ '.' + br(2) + 'Over 60% of internet users in Tamil Nadu prefer regional language content. Posting in Tamil significantly increases reach and engagement in Coimbatore.' + br(2) + 'We handle bilingual content creation as part of our service.' + br(2) + CTA_BOOK + ' to discuss your content language strategy.';
            }
            else if (n2.indexOf('negative') > -1 || n2.indexOf('bad review') > -1 || n2.indexOf('one star') > -1 || n2.indexOf('complaint') > -1) {
              fallbackReply = 'Negative reviews happen to everyone. Here is how we handle them:' + br(2) + bullet([bold('Respond professionally')+ ' within 24 hours showing empathy and resolution',bold('Never argue')+ ' publicly. Take the conversation offline',bold('Encourage satisfied patients')+ ' to share their experience (drowns out negatives)',bold('Report fake reviews')+ ' that violate Google guidelines',bold('Learn from feedback')+ ' to improve patient experience']) + br(2) + 'A few negative reviews among many positive ones actually increases '+bold('credibility')+ '.' + br(2) + CTA_BOOK + ' for a reputation management strategy.';
            }
            else if (n2.indexOf('outrank') > -1 || n2.indexOf('beat competitor') > -1 || n2.indexOf('top position') > -1) {
              fallbackReply = 'To '+bold('outrank competitors on Google')+':' + br(2) + bullet(['Optimize Google Business Profile with complete info and regular posts','Build more genuine reviews than competitors','Create location-specific content for your area','Ensure consistent NAP (Name, Address, Phone) across directories','Build a fast, mobile-optimized clinic website','Earn local citations and backlinks']) + br(2) + 'We perform a complete '+bold('competitor analysis')+ ' to identify exactly where you can win.' + br(2) + CTA_BOOK + ' for a free competitive analysis.';
            }
            else {
              // Ultimate fallback — still helpful
              var contextHint = ctx.specialty ? ' for your '+ctx.specialty+' practice' : '';
              fallbackReply = '🤔 That is a great question! Let me help you with that.' + br(2) +
                'I can assist with:' + br() +
                bullet([
                  bold('Social Media Marketing') + ' for doctors',
                  bold('Local SEO & Google Ranking'),
                  bold('Paid Advertising') + ' (Facebook/Instagram/Google)',
                  bold('Reputation & Review Management'),
                  bold('Personal Branding'),
                  bold('Clinic Website Development'),
                  bold('Patient Acquisition Strategies')
                ]) + br(2) +
                'For a detailed answer'+contextHint+', I recommend a quick chat with our growth team:' + br(2) +
                CTA_BOOK + ' | ' + CTA_WA + br(2) +
                'Or feel free to ask me something more specific!';
              qr = [
                {label:'Social media help', reply:'Tell me about social media marketing for doctors'},
                {label:'SEO & Google ranking', reply:'How can I rank on Google'},
                {label:'Get more patients', reply:'How to get more patients to my clinic'},
                {label:'Talk to someone', reply:'I want to book a free consultation'}
              ];
            }

            r = fallbackReply;
            break;
        }

        addBotMsg(r);
        // Show follow-up quick replies if available
        if (qr && qr.length > 0) {
          setTimeout(function() { showQuickReplies(qr); scrollBottom(); }, 400);
        }
      }

      /* ─── Show initial quick replies ─── */
      showQuickReplies([
        {label:'Social media for my clinic', reply:'I want to grow my clinic social media presence'},
        {label:'Rank on Google', reply:'How can I rank my clinic higher on Google'},
        {label:'Pricing & plans', reply:'What are your pricing plans and packages'},
        {label:'Book free consultation', reply:'I want to book a free growth consultation'}
      ]);

      /* ─── UI: Tooltip ─── */
      setTimeout(function() { if (!isOpen && !tooltipDismissed) chatTooltip.classList.add('visible'); }, 3000);
      setTimeout(function() { if (!tooltipDismissed) chatTooltip.classList.remove('visible'); }, 11000);
      tooltipClose.addEventListener('click', function(e) { e.stopPropagation(); chatTooltip.classList.remove('visible'); tooltipDismissed = true; });

      /* ─── UI: Open / Close ─── */
      chatbotFab.addEventListener('click', function() {
        isOpen = !isOpen;
        if (isOpen) {
          chatbotWindow.style.display = 'flex';
          chatTooltip.classList.remove('visible');
          tooltipDismissed = true;
          chatbotWindow.offsetHeight;
          chatbotWindow.classList.add('open');
          chatbotFab.classList.add('active');
          chatbotInput.focus();
        } else { closeChatbot(); }
      });
      chatbotClose.addEventListener('click', function() { isOpen = false; closeChatbot(); });

      function closeChatbot() {
        chatbotWindow.classList.remove('open');
        chatbotFab.classList.remove('active');
        setTimeout(function() { if (!isOpen) chatbotWindow.style.display = 'none'; }, 350);
      }

      /* ─── UI: Quick Replies ─── */
      quickReplies.addEventListener('click', function(e) {
        var btn = e.target.closest('.srt-quick-btn');
        if (!btn) return;
        var msg = btn.getAttribute('data-reply');
        addUserMsg(msg);
        quickReplies.style.display = 'none';
        showTyping();
        var delay = 800 + Math.random() * 600;
        setTimeout(function() { removeTyping(); getResponse(detectIntent(msg), msg); }, delay);
      });

      /* ─── UI: Form Submit ─── */
      chatbotForm.addEventListener('submit', function(e) {
        e.preventDefault();
        var val = chatbotInput.value.trim();
        if (!val) return;
        addUserMsg(val);
        chatbotInput.value = '';
        quickReplies.style.display = 'none';
        showTyping();
        var delay = 600 + Math.min(val.length * 20, 1200);
        setTimeout(function() { removeTyping(); getResponse(detectIntent(val), val); }, delay);
      });

      /* ─── UI: Message helpers ─── */
      function addUserMsg(text) {
        var div = document.createElement('div');
        div.className = 'srt-chat-msg srt-chat-user';
        div.innerHTML = '<div class="srt-chat-bubble">' + escapeHtml(text) + '</div><span class="srt-chat-time">' + getTime() + '</span>';
        chatbotBody.appendChild(div);
        scrollBottom();
      }

      function addBotMsg(html) {
        var div = document.createElement('div');
        div.className = 'srt-chat-msg srt-chat-bot';
        div.innerHTML = '<div class="srt-chat-bubble">' + html + '</div><span class="srt-chat-time">' + getTime() + '</span>';
        chatbotBody.appendChild(div);
        scrollBottom();
      }

      function showTyping() {
        var div = document.createElement('div');
        div.className = 'srt-typing'; div.id = 'srtTypingIndicator';
        div.innerHTML = '<div class="srt-typing-dot"></div><div class="srt-typing-dot"></div><div class="srt-typing-dot"></div>';
        chatbotBody.appendChild(div); scrollBottom();
      }

      function removeTyping() { var el = document.getElementById('srtTypingIndicator'); if (el) el.remove(); }
      function scrollBottom() { chatbotBody.scrollTop = chatbotBody.scrollHeight; }

    })();