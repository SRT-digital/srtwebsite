      function link(href, text) { return '<a href="'+href+'" style="color:#25bbcc;text-decoration:underline;">'+text+'</a>'; }
      function bold(t) { return '<strong>'+t+'</strong>'; }
      function br(n) { var s=''; for(var i=0;i<(n||1);i++) s+='<br>'; return s; }
      function bullet(items) { return items.map(function(i){ return '&bull; '+i; }).join('<br>'); }
      function getTime() { var n=new Date(); return n.getHours().toString().padStart(2,'0')+':'+n.getMinutes().toString().padStart(2,'0'); }
      function escapeHtml(s) { var d=document.createElement('div'); d.textContent=s; return d.innerHTML; }

      /* ─── Normalize input — remove noise, fix typos ─── */
      function normalize(s) {
        s = s.toLowerCase().trim()
          .replace(/[''`]/g, "'")
          .replace(/[""]/g, '"')
          .replace(/[^\w\s'?.,@]/g, ' ')
          .replace(/\s+/g, ' ');
        // Common misspellings / abbreviations
        var fixes = {
          'socail':'social','soical':'social','socal':'social','midea':'media','meida':'media',
          'instagaram':'instagram','insta':'instagram','ig':'instagram','fb':'facebook',
          'gogle':'google','googl':'google','googe':'google','gmb':'google business profile',
          'gbp':'google business profile','goolge':'google',
          'seo':'seo','serch':'search','seach':'search','srch':'search',
          'websit':'website','webiste':'website','wesite':'website','wbsite':'website',
          'priceing':'pricing','prcing':'pricing','prise':'price','prce':'price',
          'coimbtor':'coimbatore','cbe':'coimbatore','kovai':'coimbatore','coimbtre':'coimbatore',
          'consltation':'consultation','consultaion':'consultation','consult':'consultation',
          'pateint':'patient','patint':'patient','patien':'patient',
          'dermotologist':'dermatologist','derma':'dermatologist','skin':'dermatologist',
          'dentis':'dentist','dental':'dentist','teeth':'dentist','tooth':'dentist',
          'gynaecologist':'gynecologist','gynae':'gynecologist','gyne':'gynecologist',
          'physio':'physiotherapist','physiotherapy':'physiotherapist',
          'ivf':'ivf','fertility':'ivf','infertility':'ivf',
          'gp':'general practitioner','general doctor':'general practitioner',
          'ads':'advertising','ad':'advertising','advertisment':'advertising',
          'brandig':'branding','brandng':'branding',
          'revew':'review','reveiw':'review','reviw':'review',
          'reputaion':'reputation','reputaton':'reputation',
          'roi':'return on investment','rtrn':'return',
          'hw':'how','wht':'what','wen':'when','wher':'where','cn':'can',
          'plz':'please','pls':'please','thnk':'thank','thnks':'thanks','ty':'thanks',
          'yr':'your','ur':'your','u':'you','r':'are','m':'am',
          'dont':'do not','cant':'cannot','wont':'will not','isnt':'is not',
          'whtsapp':'whatsapp','wattsapp':'whatsapp','wa':'whatsapp',
          'pkg':'package','pkgs':'packages',
          'no ':'number ','num':'number','ph':'phone','fone':'phone',
          'erod':'erode','tamil nad':'tamil nadu',
          'doc':'doctor','dr':'doctor','docs':'doctors'
        };
        Object.keys(fixes).forEach(function(k) {
          s = s.replace(new RegExp('\\b'+k+'\\b', 'g'), fixes[k]);
        });
        return s;
      }

      /* ─── Intent scoring engine ─── */
      var intents = [
