      /* ─── Helpers ─── */
      var L = function(s){ return '<a href="./index.html#contact" style="color:#25bbcc;text-decoration:underline;font-weight:600;">'; };
      var CTA_BOOK   = '<a href="./index.html#contact" style="color:#25bbcc;text-decoration:underline;font-weight:600;">Book Free Consultation</a>';
      var CTA_WA     = '<a href="https://wa.me/919876543210?text=Hi%20SRT%2C%20I%20need%20help%20with%20my%20clinic%20growth" target="_blank" style="color:#25D366;text-decoration:underline;font-weight:600;">Chat on WhatsApp</a>';
