/* SRT Digital Solutions - Custom Theme Override */
:root {
  --theme: #25bbcc;
  --theme-2: #25bbcc;
}

/* Scale page to 80% - using font and element scaling */
html {
  font-size: 80%;
  scroll-behavior: smooth;
  -webkit-text-size-adjust: 100%;
}

body {
  line-height: 1.5;
  text-rendering: optimizeSpeed;
}

/* Performance: GPU acceleration for animated elements */
.service-item,
.portfolio-card-v2,
.funnel-bar,
.blog-item,
.specialty-item,
.srt-fab,
.srt-chatbot-window,
.tf__scroll_btn {
  will-change: transform;
  transform: translateZ(0);
  backface-visibility: hidden;
}

/* Performance: contain layout for heavy sections */
section {
  contain: layout style;
}

/* Smooth image rendering */
img {
  image-rendering: -webkit-optimize-contrast;
  image-rendering: crisp-edges;
}

/* Scale down major sections */
.container {
  max-width: 1200px;
}

h1, .section-title {
  font-size: clamp(2rem, 4vw, 3.5rem);
}

h2 {
  font-size: clamp(1.5rem, 3vw, 2.5rem);
}

h3 {
  font-size: clamp(1.1rem, 2vw, 1.5rem);
}

p {
  font-size: 1rem;
}

/* Reduce section spacing */
.mt-120 {
  margin-top: 80px !important;
}

.pt-120 {
  padding-top: 80px !important;
}

.pb-120 {
  padding-bottom: 80px !important;
}

/* Hero Section Fixes */
section.banner {
  padding-top: 120px !important;
  padding-bottom: 60px !important;
  min-height: 100vh;
  display: flex;
  align-items: center;
}

section.banner > .container {
  width: 100%;
}

section.banner .row {
  align-items: center !important;
  min-height: 70vh;
}

/* Hero Text Content */
section.banner .col-xxl-7 {
  padding-right: 30px;
}

section.banner .hero-title {
  font-size: clamp(2.8rem, 5vw, 4.5rem) !important;
  margin-bottom: 20px !important;
  line-height: 1.15;
}

section.banner .mb-18 {
  margin-bottom: 15px !important;
}

section.banner p {
  font-size: 1.1rem;
  line-height: 1.7;
  max-width: 520px;
  margin-bottom: 30px !important;
  color: rgba(255, 255, 255, 0.85);
}

section.banner .mt-40 {
  margin-top: 30px !important;
}

/* Hero Image - Better alignment */
section.banner .hero-img {
  max-width: 100%;
  width: 100%;
  max-height: 500px;
  height: auto;
  object-fit: contain;
}

section.banner .text-end {
  display: flex;
  align-items: center;
  justify-content: flex-end;
}

/* Theme color overrides */
.theme-1-bg,
.theme-2-bg {
  background-color: #25bbcc !important;
}

.color-theme-1,
.color-theme-2 {
  color: #25bbcc !important;
}

/* Button styles */
.theme-btn-with-bg {
  background-color: #25bbcc;
  border-color: #25bbcc;
}

.theme-btn-with-bg:hover {
  border-color: #25bbcc;
}

.theme-btn-with-bg .magnet-bubble {
  background-color: #25bbcc;
}

/* Service icons */
.service-item .service-icon i {
  color: #25bbcc;
}

/* Counter section */
.counter-container-wrapper {
  background-color: #25bbcc !important;
}

/* Links and accents */
a:hover {
  color: #25bbcc;
}

.sub-title::before,
.sub-title::after {
  background-color: #25bbcc;
}

.sub-title-arrows::before,
.sub-title-arrows::after {
  border-color: #25bbcc;
}

/* About list checkmarks */
.about-list ul li::before {
  color: #25bbcc;
}

/* Footer */
.footer-email i {
  color: #25bbcc;
}

/* Scroll-to-top button - hidden */
.tf__scroll_btn {
  display: none !important;
}

/* Service 2 hover */
.service-2-item:hover .service-2-icon-name i {
  color: #25bbcc;
}

.service-2-item:hover a {
  color: #25bbcc;
}

/* Blog date */
.blog-item .date {
  background-color: #25bbcc;
}

/* Theme button 3 */
.theme-btn-3:hover {
  color: #25bbcc;
}

/* Portfolio hover */
.portfolio-item:hover .portfolio-content,
.portfolio-item.active .portfolio-content {
  border-color: #25bbcc;
}

/* CTA Section */
.cta-bg {
  background: linear-gradient(135deg, #25bbcc 0%, #1a8a99 100%);
}

/* Testimonial rating */
.rating .fa-star:not(.color-gray-3) {
  color: #25bbcc;
}

/* Preloader */
.preloader-logo {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  max-width: 180px;
  height: auto;
  z-index: 10;
  animation: logoReveal 2s ease-in-out infinite alternate;
}

@keyframes logoReveal {
  0% {
    clip-path: circle(30px at 20% 50%);
    opacity: 0.7;
  }
  100% {
    clip-path: circle(100px at 80% 50%);
    opacity: 1;
  }
}

/* Header logo size */
.logo img {
  max-height: 40px;
  width: auto;
}

.nav-logo img {
  max-height: 35px;
  width: auto;
}

/* Header - Glassmorphism Effect */
.main-header {
  background: rgba(79, 95, 99, 0.76) !important;
  backdrop-filter: blur(25px) saturate(200%);
  -webkit-backdrop-filter: blur(25px) saturate(200%);
  border: 1px solid rgba(245, 248, 249, 0.79);
  border-radius: 16px;
  padding: 8px 0 !important;
  margin: 15px 30px 0;
  width: calc(100% - 60px);
  left: 0;
  top: 0;
  z-index: 9999;
}

.main-header .container {
  padding-top: 5px;
  padding-bottom: 5px;
}

/* Smaller navigation links */
.main-menu ul li a {
  padding: 8px 15px !important;
  font-size: 14px;
  color: rgba(255, 255, 255, 0.85) !important;
  transition: all 0.3s ease;
}

.main-menu ul li a:hover {
  color: #25bbcc !important;
}

/* Header button smaller - gradient style */
.main-header .theme-btn {
  padding: 10px 20px !important;
  font-size: 13px;
  background: linear-gradient(90deg, #00E1E2 0%, #00FFFE 25%, #3AF8FF 50%, #00FFFE 75%, #00E1E2 100%) !important;
  background-size: 200% 200%;
  animation: gradientShift 4s ease infinite;
  border: none !important;
  color: #0a1a2e !important;
}

.main-header .theme-btn:hover {
  background: linear-gradient(90deg, #3AF8FF 0%, #00FFFE 25%, #00E1E2 50%, #00FFFE 75%, #3AF8FF 100%) !important;
}

/* Magic cursor */
#ball {
  border-color: #25bbcc;
}

/* Banner highlight */
.banner-2-content h1 span {
  color: #25bbcc;
}

/* About 2 title span */
.about-2-title span {
  color: #25bbcc;
}

/* Resume tabs */
.resume-btns .nav-link.active {
  background-color: #25bbcc;
  border-color: #25bbcc;
}

/* Newsletter button */
.cta form button {
  background-color: #25bbcc;
}

.cta form button:hover {
  background-color: #1a8a99;
}

/* Footer form button */
.footer-form button {
  background-color: #25bbcc;
}

/* Social icons hover */
.social a:hover {
  background-color: #25bbcc;
  border-color: #25bbcc;
}

/* Selection color */
::selection {
  background-color: #25bbcc;
  color: #fff;
}

/* Hero Rotating Text Animation */
.hero-title {
  line-height: 1.2;
}

.rotating-text-wrapper {
  display: inline-block;
  position: relative;
  min-width: 300px;
  height: 1.2em;
  vertical-align: bottom;
}

.rotating-text {
  display: inline-block;
  position: absolute;
  left: 0;
  white-space: nowrap;
  opacity: 1;
  transform: translateY(0) scale(1);
  filter: blur(0);
  transition: all 0.6s cubic-bezier(0.4, 0, 0.2, 1);
}

.rotating-text.blur-out {
  opacity: 0;
  transform: translateY(-30px) scale(0.9);
  filter: blur(20px);
}

.rotating-text.blur-in {
  opacity: 0;
  transform: translateY(30px) scale(1.1);
  filter: blur(20px);
}

/* Gradient Text Effect - Cyan Shades */
.gradient-text {
  background: linear-gradient(90deg, #00E1E2 0%, #00FFFE 15%, #3AF8FF 30%, #81FBFF 50%, #C0FEFF 70%, #EDFFFE 85%, #81FBFF 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  background-size: 200% 200%;
  animation: gradientShift 4s ease infinite;
}

@keyframes gradientShift {
  0% {
    background-position: 0% 50%;
  }
  50% {
    background-position: 100% 50%;
  }
  100% {
    background-position: 0% 50%;
  }
}

/* Gradient Buttons - Get Started & Our Services */
.theme-btn,
.theme-btn-with-bg {
  background: linear-gradient(90deg, #00E1E2 0%, #00FFFE 25%, #3AF8FF 50%, #00FFFE 75%, #00E1E2 100%) !important;
  background-size: 200% 200%;
  animation: gradientShift 4s ease infinite;
  border: none !important;
  color: #0a1a2e !important;
  font-weight: 600;
}

.theme-btn:hover,
.theme-btn-with-bg:hover {
  background: linear-gradient(90deg, #3AF8FF 0%, #00FFFE 25%, #00E1E2 50%, #00FFFE 75%, #3AF8FF 100%) !important;
  color: #0a1a2e !important;
}

.theme-btn span,
.theme-btn-with-bg span {
  color: #0a1a2e !important;
}

/* Responsive rotating text */
@media (max-width: 768px) {
  .rotating-text-wrapper {
    min-width: 200px;
    display: block;
  }
}

@media (max-width: 480px) {
  .rotating-text-wrapper {
    min-width: 150px;
  }
}

/* Fix scroll and section display */
#scrollsmoother-container {
  overflow: visible !important;
}

section {
  position: relative;
  z-index: 1;
}

/* Ensure footer and CTA are visible */
footer,
.cta,
#contact {
  position: relative;
  z-index: 2;
}

/* About Section - Extend width & Glassmorphism */
#about .gray-bg {
  margin-left: 30px !important;
  margin-right: 30px !important;
  background: rgba(79, 95, 99, 0.6) !important;
  backdrop-filter: blur(25px) saturate(200%);
  -webkit-backdrop-filter: blur(25px) saturate(200%);
  border: 1px solid rgba(245, 248, 249, 0.3);
}

/* About Section Image Cards - Glassmorphism */
#about .col-sm-6 img {
  background: rgba(79, 95, 99, 0.5);
  backdrop-filter: blur(25px) saturate(200%);
  -webkit-backdrop-filter: blur(25px) saturate(200%);
  border: 1px solid rgba(245, 248, 249, 0.3);
  border-radius: 30px;
  padding: 10px;
}

/* About Counter - Glassmorphism */
.about-counter {
  background: rgba(79, 95, 99, 0.76) !important;
  backdrop-filter: blur(25px) saturate(200%);
  -webkit-backdrop-filter: blur(25px) saturate(200%);
  border: 1px solid rgba(245, 248, 249, 0.5);
}

/* Services Cards - Glassmorphism */
.service-item {
  background: rgba(79, 95, 99, 0.6) !important;
  backdrop-filter: blur(25px) saturate(200%);
  -webkit-backdrop-filter: blur(25px) saturate(200%);
  border: 1px solid rgba(245, 248, 249, 0.3) !important;
  border-radius: 20px;
  transition: all 0.3s ease;
}

.service-item:hover {
  background: rgba(79, 95, 99, 0.8) !important;
  border-color: rgba(37, 187, 204, 0.5) !important;
  transform: translateY(-5px);
}

/* Service Icons */
.service-item .service-icon {
  width: 70px;
  height: 70px;
  background: linear-gradient(135deg, #00E1E2 0%, #3AF8FF 50%, #00FFFE 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 20px;
}

.service-item .service-icon i {
  font-size: 28px;
  color: #0a1a2e !important;
}

.service-item h3 {
  color: #fff;
  margin-bottom: 15px;
}

.service-item p {
  color: rgba(255, 255, 255, 0.88);
  margin-bottom: 20px;
}

.service-item a {
  color: #25bbcc;
  font-size: 20px;
  transition: all 0.3s ease;
}

.service-item a:hover {
  color: #3AF8FF;
  transform: translateX(5px);
}

/* Fix about/service section gap */
.about-section {
  padding-bottom: 80px !important;
}
.service-section {
  margin-top: 120px !important;
}

/* Newsletter CTA Section - Glassmorphism (index-2 style) */
.cta {
  margin-top: 150px;
  margin-bottom: -100px;
}

.cta .cta-bg {
  background: rgb(71 128 143 / 74%) !important;
  backdrop-filter: blur(25px) saturate(200%);
  -webkit-backdrop-filter: blur(25px) saturate(200%);
  border: 1px solid rgba(245, 248, 249, 0.3);
  border-radius: 30px;
  overflow: visible;
  padding-bottom: 80px;
}

.cta .section-title {
  color: #fff;
}

.cta p {
  color: rgba(255, 255, 255, 0.85);
}

/* CTA Image with circular background - index-2 style */
.cta .cta-img {
  position: relative;
  z-index: 2;
  height: 351px;
  width: 351px;
  border-radius: 50%;
  bottom: -161px;
  left: 77px;
  background-color: rgba(37, 187, 204, 0.15);
}

.cta .cta-img img {
  max-width: 384px;
  position: relative;
  top: -180px;
  left: 50%;
  transform: translate(-50%, 0%);
  z-index: 2;
}

/* CTA Form Styling */
.cta form {
  display: flex;
  gap: 15px;
  margin-top: 30px;
  flex-wrap: wrap;
}

.cta form input {
  flex: 1;
  min-width: 250px;
  padding: 15px 20px;
  background: rgba(255, 255, 255, 0.1) !important;
  border: 1px solid rgba(245, 248, 249, 0.4) !important;
  border-radius: 12px;
  color: #fff !important;
  font-size: 1rem;
  outline: none;
  transition: all 0.3s ease;
}

.cta form input::placeholder {
  color: rgba(255, 255, 255, 0.6);
}

.cta form input:focus {
  background: rgba(255, 255, 255, 0.15) !important;
  border-color: #25bbcc !important;
}

.cta form button {
  padding: 15px 30px;
  background: linear-gradient(90deg, #00E1E2 0%, #00FFFE 25%, #3AF8FF 50%, #00FFFE 75%, #00E1E2 100%) !important;
  background-size: 200% 200%;
  animation: gradientShift 4s ease infinite;
  border: none !important;
  border-radius: 12px;
  color: #0a1a2e !important;
  font-weight: 600;
  font-size: 1rem;
  cursor: pointer;
  transition: all 0.3s ease;
}

.cta form button:hover {
  transform: translateY(-2px);
  box-shadow: 0 5px 20px rgba(37, 187, 204, 0.4);
}

/* Hide decorative icons */
.cta .misc-icon,
.cta .ashik-icon-ziczac-arrow {
  display: none;
}

/* ============================================
   RESPONSIVE FIXES - Mobile & Tablet
   ============================================ */

/* Tablet (991px and below) */
@media (max-width: 991px) {
  .cta {
    margin-top: 80px;
    margin-bottom: -60px;
  }
  .cta .cta-img {
    width: 280px;
    height: 280px;
    bottom: -120px;
    left: 50%;
    transform: translateX(-50%);
  }
  .cta .cta-img img {
    max-width: 320px;
  }

  /* About section glassmorphism - reduce side margins */
  #about .gray-bg {
    margin-left: 15px !important;
    margin-right: 15px !important;
  }

  /* Contact section - reduce inner padding */
  .gray-bg.pt-80.pb-80.pl-60.pr-60 {
    padding-left: 30px !important;
    padding-right: 30px !important;
  }

  /* Footer bottom bar - stack on tablet */
  .footer .mt-80 .col-lg-6.flex-lg-end {
    justify-content: flex-start !important;
    margin-top: 10px;
  }
}

/* Tablet small (768px and below) */
@media (max-width: 768px) {
  .main-header {
    margin: 10px 16px 0;
    width: calc(100% - 32px);
    border-radius: 14px;
  }
  .cta {
    margin-top: 60px;
    margin-bottom: -40px;
  }
  .cta .cta-img {
    width: 220px;
    height: 220px;
    bottom: -100px;
  }
  .cta .cta-img img {
    max-width: 260px;
    top: -170px;
  }

  /* Hero section mobile */
  section.banner {
    padding-top: 100px !important;
    padding-bottom: 40px !important;
    min-height: auto;
  }
  section.banner .row {
    min-height: auto;
  }
  section.banner p {
    max-width: 100%;
  }

  /* Section spacing reduction */
  .mt-120 {
    margin-top: 60px !important;
  }
  .pt-120 {
    padding-top: 60px !important;
  }
  .pb-120 {
    padding-bottom: 60px !important;
  }

  /* Pricing cards padding */
  .gray-bg.br-20.p-40,
  .br-20.p-40 {
    padding: 28px 22px !important;
  }

  /* FAQ items padding */
  .gray-bg.br-20.p-30 {
    padding: 22px 18px !important;
  }

  /* Blog heading - hide br on mobile */
  #blog .section-title br {
    display: none;
  }

  /* Footer menus wrap */
  .footer-menus {
    margin-top: 30px !important;
    flex-wrap: wrap;
  }

  /* Contact form select styling fix */
  #contact select {
    font-size: 14px;
    padding: 12px !important;
  }
}

/* Mobile (480px and below) */
@media (max-width: 480px) {
  .main-header {
    margin: 8px 10px 0;
    width: calc(100% - 20px);
    border-radius: 12px;
    padding: 4px 0 !important;
  }
  .cta {
    margin-top: 40px;
    margin-bottom: -20px;
  }
  .cta .cta-bg {
    padding-bottom: 40px;
    border-radius: 20px;
  }
  .cta .cta-img {
    width: 180px;
    height: 180px;
    bottom: -80px;
  }
  .cta .cta-img img {
    max-width: 220px;
    top: -140px;
  }

  /* Hero mobile */
  section.banner .hero-title {
    font-size: clamp(1.8rem, 6vw, 2.5rem) !important;
  }

  /* Section spacing further reduction */
  .mt-120 {
    margin-top: 40px !important;
  }
  .mt-60 {
    margin-top: 30px !important;
  }

  /* About section - no side margins */
  #about .gray-bg {
    margin-left: 0 !important;
    margin-right: 0 !important;
    border-radius: 16px;
  }

  /* Contact section inner padding */
  .gray-bg.pt-80.pb-80 {
    padding-top: 40px !important;
    padding-bottom: 40px !important;
  }
  .gray-bg.pt-80.pb-80.pl-60.pr-60 {
    padding-left: 16px !important;
    padding-right: 16px !important;
    border-radius: 20px !important;
  }

  /* Pricing cards mobile */
  .gray-bg.br-20.p-40,
  .br-20.p-40 {
    padding: 24px 18px !important;
  }

  /* CTA form stacking */
  .cta form {
    flex-direction: column;
  }
  .cta form input {
    min-width: 100%;
  }

  /* Footer bottom bar */
  .footer .mt-80 {
    margin-top: 40px !important;
  }
  .footer .mt-80 p {
    font-size: 12px;
  }
  .copyright-menus a {
    font-size: 12px;
  }

  /* Service icon size reduction */
  .service-item .service-icon {
    width: 56px;
    height: 56px;
  }
  .service-item .service-icon i {
    font-size: 22px;
  }
}

/* Small mobile (375px and below) */
@media (max-width: 375px) {
  .main-header {
    margin: 6px 8px 0;
    width: calc(100% - 16px);
  }
  .hero-title {
    font-size: 1.7rem;
  }
  .rotating-text-wrapper {
    min-width: 120px;
  }

  /* Tighter spacing */
  .gray-bg.br-20.p-40,
  .br-20.p-40 {
    padding: 20px 14px !important;
  }
  .gray-bg.br-20.p-30 {
    padding: 18px 14px !important;
  }

  /* Footer email text */
  .footer-email-text a {
    font-size: 14px;
    word-break: break-all;
  }
}

/* ============================================
   SRT Popup System - 4 Template Styles
   ============================================ */

/* Wrapper & Animations */
.srt-popup-wrapper {
  position: fixed;
  z-index: 100001;
  opacity: 0;
  transition: opacity 0.3s ease;
}

.srt-popup-wrapper.srt-popup-active { opacity: 1; }
.srt-popup-wrapper.srt-popup-closing { opacity: 0; }

/* Overlay */
.srt-popup-overlay {
  position: fixed;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100001;
  padding: 20px;
}

/* Close button */
.srt-popup-close {
  position: absolute;
  top: 12px;
  right: 14px;
  background: none;
  border: none;
  color: inherit;
  font-size: 24px;
  cursor: pointer;
  opacity: 0.6;
  transition: opacity 0.2s;
  line-height: 1;
}

.srt-popup-close:hover { opacity: 1; }

/* Content shared */
.srt-popup-title {
  margin: 0 0 8px;
  font-size: 22px;
  font-weight: 700;
}

.srt-popup-subtitle {
  opacity: 0.7;
  font-size: 14px;
  margin: 0 0 12px;
}

.srt-popup-desc {
  font-size: 14px;
  opacity: 0.85;
  margin: 0 0 20px;
  line-height: 1.6;
}

.srt-popup-actions {
  display: flex;
  gap: 10px;
  justify-content: center;
  flex-wrap: wrap;
}

.srt-popup-btn-primary {
  display: inline-block;
  padding: 10px 28px;
  color: #fff;
  text-decoration: none;
  border-radius: 6px;
  font-size: 14px;
  font-weight: 600;
  border: none;
  cursor: pointer;
  transition: opacity 0.2s;
}

.srt-popup-btn-primary:hover { opacity: 0.85; color: #fff; text-decoration: none; }

.srt-popup-btn-secondary {
  display: inline-block;
  padding: 10px 24px;
  background: transparent;
  border: 1px solid rgba(255,255,255,0.3);
  color: inherit;
  border-radius: 6px;
  font-size: 13px;
  cursor: pointer;
  transition: border-color 0.2s;
}

.srt-popup-btn-secondary:hover { border-color: rgba(255,255,255,0.6); }

/* Template 1: Centered Modal */
.srt-popup-centered {
  position: relative;
  border-radius: 12px;
  padding: 40px 36px;
  max-width: 480px;
  width: 100%;
  text-align: center;
  box-shadow: 0 20px 60px rgba(0,0,0,0.4);
}

/* Template 2: Bottom Bar */
.srt-popup-bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 100001;
  padding: 0;
  box-shadow: 0 -4px 20px rgba(0,0,0,0.3);
}

.srt-popup-bar-inner {
  display: flex;
  align-items: center;
  gap: 16px;
  padding: 14px 24px;
  max-width: 1200px;
  margin: 0 auto;
}

.srt-popup-bar-text {
  flex: 1;
  font-size: 14px;
}

.srt-popup-bar-text strong { margin-right: 6px; }

.srt-popup-close-bar {
  background: none;
  border: none;
  color: inherit;
  font-size: 22px;
  cursor: pointer;
  opacity: 0.6;
  padding: 0 4px;
}

.srt-popup-close-bar:hover { opacity: 1; }

/* Template 3: Slide-in Right */
.srt-popup-slide-right {
  position: fixed;
  bottom: 24px;
  right: 24px;
  z-index: 100001;
  border-radius: 12px;
  padding: 28px 24px;
  max-width: 340px;
  width: 100%;
  box-shadow: 0 12px 40px rgba(0,0,0,0.4);
  transform: translateX(120%);
  transition: transform 0.4s ease;
}

.srt-popup-active .srt-popup-slide-right { transform: translateX(0); }
.srt-popup-closing .srt-popup-slide-right { transform: translateX(120%); }

/* Template 4: Full Screen */
.srt-popup-fullscreen {
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
}

.srt-popup-full-inner {
  max-width: 700px;
  padding: 40px 24px;
}

.srt-popup-close-full {
  top: 20px;
  right: 24px;
  font-size: 32px;
}

/* Popup responsive */
@media (max-width: 768px) {
  .srt-popup-centered { padding: 28px 20px; margin: 12px; }
  .srt-popup-bar-inner { flex-direction: column; gap: 10px; text-align: center; }
  .srt-popup-slide-right { right: 12px; bottom: 12px; max-width: calc(100vw - 24px); }
  .srt-popup-close-full { top: 12px; right: 16px; }
}
